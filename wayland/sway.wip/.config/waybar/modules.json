    // Sway Mode, i.e Resize
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    // Current window Name
    "sway/window": {
        "separate-outputs": true,
        "format": "<span style=\"italic\">{}</span>"
    },
    // Idle Inibitor (Tells sway if it should lock your system is not active after a period of time)
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пПБ",
            "deactivated": "пА£"
        }
    },
    // Clock Settings
    "clock": {
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#cc8a3a'><b>{}</b></span>", // Amber (header)
                "days": "<span color='#f2e7cc'>{}</span>", // Parchment
                "weeks": "<span color='#9a8a5a'>W{}</span>", // Muted brass
                "weekdays": "<span color='#e6b35c'><b>{}</b></span>", // Soft amber
                "today": "<span background='#3a2a1a' color='#fff8e1'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        },
        "format": "{:%a %d %b | %I:%M %p}", //12 hour format
        "format-alt": "пД≥  {:%Y-%m-%d пАЧ %H:%M:%S}",
        "interval": 1
    },
    // Cpu Settings 
    "cpu": {
        "format": "CPU{usage: >3}%",
        // Opens foot terminal with htop
        // "on-click": "foot -e htop" 
        //TODO: Open as Float 
    },
    "memory": {
        "format": "MEM{: >3}%",
        // "on-click": "foot -e htop" 
        //TODO: Open as Float 
    },
    // Custom Nvidia Drivers
    "custom/gpu_temp": {
        "thermal-zone": 4,
        "critical-threshold": 80,
        "exec": "nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits",
        "format-critical": "{temperatureC}¬∞C пЛЗ",
        "format": "пЛЙ  {}¬∞C"
    },
    // Main Nvidia Drivers
    "temperature": {
        "thermal-zone": 4,
        // "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "critical-threshold": 80,
        "format-critical": "{temperatureC}¬∞C пЛЗ",
        "format": "пЛЙ  {temperatureC}¬∞C"
    },
    // Harddisc space used
    "disk": {
        // "interval": 30,
        "format": "DSK {percentage_used}% ",
        "path": "/",
        //"on-click": "alacritty -e htop"
    },
    // Brightness Control
    "backlight": {
        "device": "acpi_video1",
        "format": "{icon} {percent: >3}%",
        "format-icons": [
            "пЖЕ",
            "пДС"
        ],
        "format-icons": [
            "оОН",
            "оПУ",
            "оПС",
            "оПП",
            "оПО",
            "оПН",
            "оПК",
            "оПИ",
            "оОЫ"
        ],
        // "on-scroll-down": "brightnessctl -c backlight set 5%-",
        // "on-scroll-down": "light -A 5 && light -G | cut -d'.' -f1 > $SWAYSOCK.wob",
        // "on-scroll-up": "brightnessctl -c backlight set +5%",
        // "on-scroll-up": "light -U 5 && light -G | cut -d'.' -f1 > $SWAYSOCK.wob",
        // "on-click": ""
    },
    // Battery Config
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "BAT {capacity: >3}%",
        "format-alt": "BAT {time}"
        // "format": "{icon}  {capacity: >3}%",
        // "format-charging": "пЧІ  {capacity}%",
        // "format-plugged": "пЗ¶  {capacity}%",
        // "format-alt": "{icon}  {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        // "format-icons": [
        //     "пЙД",
        //     "пЙГ",
        //     "пЙВ",
        //     "пЙБ",
        //     "пЙА"
        // ]
    },
    // Network Config
    "network": {
        // "interface": "wlp2s0", // (Optional) To force the use of this interface
        "format": "вЪ†  Disabled",
        "format-wifi": "пЗЂ   {essid}",
        // "format-ethernet": "пГБ {ifname}: {ipaddr}/{cidr}",
        "format-ethernet": "пГБ  Wired",
        "format-disconnected": "вЪ†  Disconnected",
        "tooltip-format": "пЮЦ {ifname} via {gwaddri}",
        // "tooltip-format-wifi": "пЗЂ   {essid} ({signalStrength}%)",
        "tooltip-format-wifi": "пЗЂ   {essid} ({ipaddr}/{cidr})",
        "tooltip-format-ethernet": "пГБ  {ifname} ({ipaddr}/{cidr})",
        "tooltip-format-disconnected": "вЪ†  Disconnected",
        // "on-click": "alacritty -e nmtui"
        // "on-click": "nm-connection-editor"
    },
    // Audio Config
    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon} {volume: >3}%",
        "format-bluetooth": "{icon} {volume: >3}%",
        "format-muted": "пА¶ muted",
        "format-icons": {
            "headphones": "у∞ЛЛ",
            "handsfree": "у∞Пі",
            "headset": "у∞ЛО",
            "phone": "",
            "portable": "у∞УГ",
            "car": "",
            "default": [
                "у∞Хњ",
                "у∞ЦА",
                "у∞ХЊ"
            ]
        },
        // "on-click": "pavucontrol",
        // "on-scroll-up": "pamixer -ui 2 && pamixer --get-volume > $SWAYSOCK.wob",
        // "on-scroll-down": "pamixer -ud 2 && pamixer --get-volume > $SWAYSOCK.wob"
        // "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
        // "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
    },
    // Custom Power Script
    "custom/power": {
        "format": "вПї",
        "on-click": "~/.config/scripts/sys/logout.sh",
        "tooltip": false
    }
