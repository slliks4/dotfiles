#!/usr/bin/env bash

STATE_FILE="/tmp/i3_split_toggle"

# default state
if [ ! -f "$STATE_FILE" ]; then
    echo "main" > "$STATE_FILE"
fi

STATE=$(cat "$STATE_FILE")

if [ "$STATE" = "main" ]; then
    # make MAIN bigger (65%)
    i3-msg '
        [con_mark="main"] focus;
        focus parent;
        resize set width 65 ppt;
        [con_mark="main"] focus
    '
    echo "aside" > "$STATE_FILE"
else
    # 👉 make ASIDE bigger (65%)
    i3-msg '
        [con_mark="aside"] focus;
        focus parent;
        resize set width 65 ppt;
        [con_mark="aside"] focus
    '
    echo "main" > "$STATE_FILE"
fi
