#!/usr/bin/env bash

# -----------------------------
# Detection
# -----------------------------
has_main_terminal() {
    i3-msg -t get_tree | jq -e \
    '.. | objects | select(.window_properties.class? == "Alacritty" and .name? == "main-terminal")' \
    >/dev/null
}

has_firefox_dev() {
    i3-msg -t get_tree | jq -e \
    '.. | objects | select(.window_properties.class? == "firefox-developer-edition")' \
    >/dev/null
}

has_qutebrowser() {
    i3-msg -t get_tree | jq -e \
    '.. | objects | select(.window_properties.class? == "qutebrowser")' \
    >/dev/null
}

# -----------------------------
# Helpers
# -----------------------------
wait_for_window() {
    local query="$1"
    while ! i3-msg -t get_tree | jq -e "$query" >/dev/null; do
        sleep 0.05
    done
}

# -----------------------------
# Step 1: Clean workspace 0
# -----------------------------
i3-msg "workspace 0"

while i3-msg -t get_tree | jq -e '
.. | objects
| select(.type? == "workspace" and .name == "0")
| .nodes[]?' >/dev/null; do
    i3-msg '[workspace="0"] focus; move container to workspace 8'
done

i3-msg "workspace 0"

# -----------------------------
# Step 2: Ensure apps exist
# -----------------------------
if ! has_main_terminal; then
    i3-msg 'exec alacritty --title main-terminal'
    wait_for_window '.. | objects | select(.window_properties.class? == "Alacritty" and .name? == "main-terminal")'
fi

if ! has_firefox_dev; then
    i3-msg 'exec firefox-developer-edition'
    wait_for_window '.. | objects | select(.window_properties.class? == "firefox-developer-edition")'
fi

if ! has_qutebrowser; then
    i3-msg 'exec qutebrowser'
    wait_for_window '.. | objects | select(.window_properties.class? == "qutebrowser")'
fi

# -----------------------------
# Step 3: Move everything to workspace 0
# -----------------------------
i3-msg '[title="main-terminal"] move to workspace 0'
i3-msg '[class="firefox-developer-edition"] move to workspace 0'
i3-msg '[class="qutebrowser"] move to workspace 0'

i3-msg "workspace 0"

# -----------------------------
# Step 4: STACK EVERYTHING FIRST (your rule)
# -----------------------------
i3-msg 'layout stacking'

# -----------------------------
# Step 5: Mark roles
# -----------------------------
i3-msg '[title="main-terminal"] mark main'
i3-msg '[class="firefox-developer-edition"] mark aside'

# Move qutebrowser into aside stack
i3-msg '[class="qutebrowser"] move container to mark aside'

# -----------------------------
# Step 6: EXTRACT MAIN → LEFT/RIGHT
# -----------------------------

# focus main
i3-msg '[con_mark="main"] focus'

# go to shared parent
i3-msg 'focus parent'

# split into left/right
i3-msg 'split h'

# move main to right
i3-msg '[con_mark="main"] move right'

# -----------------------------
# create container INSIDE main
# -----------------------------
i3-msg '[con_mark="main"] focus'
i3-msg 'split v'

# apply layout INSIDE main
i3-msg 'layout tabbed'

# -----------------------------
# Step 7: Ensure aside is stacked
# -----------------------------
i3-msg '[con_mark="aside"] focus'
i3-msg 'layout stacking'

# -----------------------------
# Step 8: Set main dominant (65%) and focus it
# -----------------------------
i3-msg '
    [con_mark="main"] focus;
    focus parent;
    resize set width 65 ppt;
    [con_mark="main"] focus
'
